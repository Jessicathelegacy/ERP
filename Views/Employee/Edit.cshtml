@model EmployeeEditViewModel
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-10">

        <ul class="nav nav-tabs mb-0" id="editTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="details-tab" data-bs-toggle="tab" data-bs-target="#details"
                        type="button" role="tab">
                    <i class="bi bi-person-fill me-1"></i>Details
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="history-tab" data-bs-toggle="tab" data-bs-target="#history"
                        type="button" role="tab">
                    <i class="bi bi-clock-history me-1"></i>Payroll History
                    @if (Model.PayrollHistory.Any())
                    {
                        <span class="badge bg-primary-subtle text-primary ms-1">@Model.PayrollHistory.Count</span>
                    }
                </button>
            </li>
        </ul>

        <div class="tab-content">

            @* Details Tab *@
            <div class="tab-pane fade show active" id="details" role="tabpanel">
                <div class="card shadow-sm border-top-0 rounded-top-0">
                    <div class="card-body p-4">
                        <form asp-action="Edit" asp-route-id="@Model.Employee.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Employee.Id" />

                            <div class="mb-3">
                                <label asp-for="Employee.Name" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                                <input asp-for="Employee.Name" class="form-control" placeholder="e.g. John Smith" />
                                <span asp-validation-for="Employee.Name" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Employee.Email" class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                                <input asp-for="Employee.Email" type="email" class="form-control" placeholder="e.g. john@example.com" />
                                <span asp-validation-for="Employee.Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Employee.Phone" class="form-label fw-semibold">Phone</label>
                                <input asp-for="Employee.Phone" class="form-control" placeholder="e.g. +1 555 000 0000" />
                                <span asp-validation-for="Employee.Phone" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Employee.PaymentSchemeId" class="form-label fw-semibold">Payment Scheme <span class="text-danger">*</span></label>
                                <select asp-for="Employee.PaymentSchemeId" asp-items="ViewBag.PaymentSchemes" class="form-select">
                                    <option value="">— Select a scheme —</option>
                                </select>
                                <span asp-validation-for="Employee.PaymentSchemeId" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Employee.JoinDate" class="form-label fw-semibold">Join Date <span class="text-danger">*</span></label>
                                <input asp-for="Employee.JoinDate" type="date" class="form-control" />
                                <span asp-validation-for="Employee.JoinDate" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input asp-for="Employee.IsActive" class="form-check-input" role="switch" />
                                    <label asp-for="Employee.IsActive" class="form-check-label fw-semibold">Active</label>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary px-4">
                                    <i class="bi bi-check-lg me-1"></i>Save Changes
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                    <i class="bi bi-x-lg me-1"></i>Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            @* Payroll History Tab *@
            <div class="tab-pane fade" id="history" role="tabpanel">
                <div class="card shadow-sm border-top-0 rounded-top-0">
                    <div class="card-body p-0">
                        @if (Model.PayrollHistory.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4">Pay Period</th>
                                            <th class="text-end">Basic</th>
                                            <th class="text-end">OT Pay</th>
                                            <th class="text-end">Allowances</th>
                                            <th class="text-end">Deductions</th>
                                            <th class="text-end">Net Salary</th>
                                            <th class="text-center">Status</th>
                                            <th class="text-center pe-4" style="width:60px"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in Model.PayrollHistory)
                                        {
                                            <tr>
                                                <td class="ps-4 small">
                                                    <span class="fw-semibold">@p.PayPeriodStart.ToString("MMM yyyy")</span>
                                                    <div class="text-muted" style="font-size:.75rem">
                                                        @p.PayPeriodStart.ToString("dd MMM") – @p.PayPeriodEnd.ToString("dd MMM yyyy")
                                                    </div>
                                                </td>
                                                <td class="text-end small">@p.BasicSalary.ToString("N2")</td>
                                                <td class="text-end small">@p.OvertimePay.ToString("N2")</td>
                                                <td class="text-end small">@p.Allowances.ToString("N2")</td>
                                                <td class="text-end small text-danger">@p.Deductions.ToString("N2")</td>
                                                <td class="text-end fw-semibold">@p.NetSalary.ToString("N2")</td>
                                                <td class="text-center">
                                                    @switch (p.Status)
                                                    {
                                                        case PayrollStatus.Paid:
                                                            <span class="badge rounded-pill bg-success-subtle text-success px-3 py-2">
                                                                <i class="bi bi-check-circle-fill me-1"></i>Paid
                                                            </span>
                                                            break;
                                                        case PayrollStatus.Approved:
                                                            <span class="badge rounded-pill bg-info-subtle text-info px-3 py-2">
                                                                <i class="bi bi-patch-check-fill me-1"></i>Approved
                                                            </span>
                                                            break;
                                                        default:
                                                            <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2">
                                                                <i class="bi bi-pencil-fill me-1"></i>Draft
                                                            </span>
                                                            break;
                                                    }
                                                </td>
                                                <td class="text-center pe-4">
                                                    <a asp-controller="Payslip" asp-action="Print" asp-route-id="@p.Id"
                                                       target="_blank" class="btn btn-sm btn-outline-secondary" title="Print Payslip">
                                                        <i class="bi bi-printer-fill"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <div class="empty-state-icon mx-auto mb-3">
                                    <i class="bi bi-clock-history"></i>
                                </div>
                                <h6 class="fw-semibold text-dark mb-1">No payroll records yet</h6>
                                <p class="text-muted small mb-0">Payroll history will appear here once processed.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
