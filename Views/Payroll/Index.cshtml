@model IEnumerable<PayrollListViewModel>
@{
    ViewData["Title"] = "Payroll";
    bool hasFilter = !string.IsNullOrWhiteSpace(ViewBag.Search as string)
                  || (ViewBag.Year  as int?) != null
                  || (ViewBag.Month as int?) != null
                  || !string.IsNullOrWhiteSpace(ViewBag.Status as string);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-receipt-cutoff me-2 text-primary"></i>Payroll Records</span>
        <a asp-action="Create" class="btn btn-primary btn-sm px-3">
            <i class="bi bi-plus-lg me-1"></i>Add New
        </a>
    </div>

    @* Filter bar *@
    <div class="card-body border-bottom pb-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label small fw-semibold mb-1">Employee</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Employee name…" />
                </div>
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-semibold mb-1">Year</label>
                <select name="year" class="form-select form-select-sm">
                    <option value="">All Years</option>
                    @foreach (int y in ViewBag.Years)
                    {
                        <option value="@y" selected="@((ViewBag.Year as int?) == y ? "selected" : null)">@y</option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-semibold mb-1">Month</label>
                <select name="month" class="form-select form-select-sm">
                    <option value="">All Months</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@((ViewBag.Month as int?) == m ? "selected" : null)">
                            @(new DateTime(2000, m, 1).ToString("MMMM"))
                        </option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-semibold mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    <option value="draft"    selected="@(ViewBag.Status == "draft"    ? "selected" : null)">Draft</option>
                    <option value="approved" selected="@(ViewBag.Status == "approved" ? "selected" : null)">Approved</option>
                    <option value="paid"     selected="@(ViewBag.Status == "paid"     ? "selected" : null)">Paid</option>
                </select>
            </div>
            <div class="col-6 col-sm-auto d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary px-3">
                    <i class="bi bi-funnel-fill me-1"></i>Filter
                </button>
                @if (hasFilter)
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3">
                        <i class="bi bi-x-lg me-1"></i>Clear
                    </a>
                }
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width:40px">#</th>
                            <th>Employee</th>
                            <th class="text-center">Pay Period</th>
                            <th class="text-end">Basic</th>
                            <th class="text-end">OT Pay</th>
                            <th class="text-end">Allowances</th>
                            <th class="text-end">Deductions</th>
                            <th class="text-end">Gross</th>
                            <th class="text-end">Net Salary</th>
                            <th class="text-center">Status</th>
                            <th class="text-center pe-4" style="width:80px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int row = (ViewBag.Page - 1) * ViewBag.PageSize + 1; }
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@row</td>
                                <td class="fw-semibold">@p.EmployeeName</td>
                                <td class="text-center small">
                                    <span class="fw-semibold">@p.PayPeriodStart.ToString("MMM yyyy")</span>
                                    <div class="text-muted" style="font-size:.72rem">
                                        @p.PayPeriodStart.ToString("dd MMM") – @p.PayPeriodEnd.ToString("dd MMM")
                                    </div>
                                </td>
                                <td class="text-end small">@p.BasicSalary.ToString("N2")</td>
                                <td class="text-end small">@p.OvertimePay.ToString("N2")</td>
                                <td class="text-end small">@p.Allowances.ToString("N2")</td>
                                <td class="text-end small text-danger">@p.Deductions.ToString("N2")</td>
                                <td class="text-end small">@p.GrossSalary.ToString("N2")</td>
                                <td class="text-end fw-semibold">@p.NetSalary.ToString("N2")</td>
                                <td class="text-center">
                                    @switch (p.Status)
                                    {
                                        case PayrollStatus.Paid:
                                            <span class="badge rounded-pill bg-success-subtle text-success px-3 py-2">
                                                <i class="bi bi-check-circle-fill me-1"></i>Paid
                                            </span>
                                            break;
                                        case PayrollStatus.Approved:
                                            <span class="badge rounded-pill bg-info-subtle text-info px-3 py-2">
                                                <i class="bi bi-patch-check-fill me-1"></i>Approved
                                            </span>
                                            break;
                                        default:
                                            <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2">
                                                <i class="bi bi-pencil-fill me-1"></i>Draft
                                            </span>
                                            break;
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-controller="Payslip" asp-action="Print" asp-route-id="@p.Id"
                                       target="_blank" class="btn btn-sm btn-outline-secondary" title="Print Payslip">
                                        <i class="bi bi-printer-fill"></i>
                                    </a>
                                </td>
                            </tr>
                            row++;
                        }
                    </tbody>
                </table>
            </div>
            @await Html.PartialAsync("_Pagination")
        }
        else
        {
            <div class="text-center py-5">
                <div class="empty-state-icon mx-auto mb-3">
                    <i class="bi bi-receipt-cutoff"></i>
                </div>
                @if (hasFilter)
                {
                    <h6 class="fw-semibold text-dark mb-1">No matching payroll records</h6>
                    <p class="text-muted small mb-4">Try adjusting your filters.</p>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg me-1"></i>Clear Filters
                    </a>
                }
                else
                {
                    <h6 class="fw-semibold text-dark mb-1">No payroll records yet</h6>
                    <p class="text-muted small mb-4">Add the first payroll record to get started.</p>
                    <a asp-action="Create" class="btn btn-primary px-4">
                        <i class="bi bi-plus-lg me-1"></i>Add Payroll
                    </a>
                }
            </div>
        }
    </div>
</div>
