@model PayrollBatch
@{
    ViewData["Title"] = "Create Batch";
    var months = Enumerable.Range(1, 12)
        .Select(m => new { Value = m, Text = new DateTime(2000, m, 1).ToString("MMMM") });
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center">
                <i class="bi bi-plus-circle-fill me-2 text-primary"></i>
                <span class="fw-semibold">New Payroll Batch</span>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    @* Period *@
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Year" class="form-label fw-semibold">Year <span class="text-danger">*</span></label>
                            <input asp-for="Year" id="Year" type="number" min="2000" max="2100" class="form-control" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Month" class="form-label fw-semibold">Month <span class="text-danger">*</span></label>
                            <select asp-for="Month" id="Month" class="form-select">
                                @foreach (var m in months)
                                {
                                    <option value="@m.Value">@m.Text</option>
                                }
                            </select>
                            <span asp-validation-for="Month" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <input asp-for="Description" class="form-control" placeholder="e.g. January 2026 Monthly Payroll" />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-info border-0 mb-3 py-2 small">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Payroll records will be <strong>automatically created</strong> for all active employees using their payment scheme rates. Totals are calculated from those records.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" name="action" value="draft" class="btn btn-secondary px-4">
                            <i class="bi bi-file-earmark me-1"></i>Draft
                        </button>
                        <button type="submit" name="action" value="submit" class="btn btn-primary px-4">
                            <i class="bi bi-send me-1"></i>Submit
                        </button>
<a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
