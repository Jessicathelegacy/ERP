@model IEnumerable<PayrollBatch>
@{
    ViewData["Title"] = "Batch Payroll";
    bool hasFilter = (ViewBag.Year  as int?) != null
                  || (ViewBag.Month as int?) != null
                  || !string.IsNullOrWhiteSpace(ViewBag.Status as string);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-layers-fill me-2 text-primary"></i>Payroll Batches</span>
        <a asp-action="Create" class="btn btn-primary btn-sm px-3">
            <i class="bi bi-plus-lg me-1"></i>New Batch
        </a>
    </div>

    @* Filter bar *@
    <div class="card-body border-bottom pb-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-semibold mb-1">Year</label>
                <select name="year" class="form-select form-select-sm">
                    <option value="">All Years</option>
                    @foreach (int y in ViewBag.Years)
                    {
                        <option value="@y" selected="@((ViewBag.Year as int?) == y ? "selected" : null)">@y</option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-semibold mb-1">Month</label>
                <select name="month" class="form-select form-select-sm">
                    <option value="">All Months</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@((ViewBag.Month as int?) == m ? "selected" : null)">
                            @(new DateTime(2000, m, 1).ToString("MMMM"))
                        </option>
                    }
                </select>
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-semibold mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    <option value="pending"    selected="@(ViewBag.Status == "pending"    ? "selected" : null)">Pending (Draft + Processing)</option>
                    <option value="draft"      selected="@(ViewBag.Status == "draft"      ? "selected" : null)">Draft</option>
                    <option value="submitted"  selected="@(ViewBag.Status == "submitted"  ? "selected" : null)">Submitted</option>
                    <option value="rejected"   selected="@(ViewBag.Status == "rejected"   ? "selected" : null)">Rejected</option>
                    <option value="processing" selected="@(ViewBag.Status == "processing" ? "selected" : null)">Processing</option>
                    <option value="completed"  selected="@(ViewBag.Status == "completed"  ? "selected" : null)">Completed</option>
                    <option value="cancelled"  selected="@(ViewBag.Status == "cancelled"  ? "selected" : null)">Cancelled</option>
                </select>
            </div>
            <div class="col-6 col-sm-auto d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary px-3">
                    <i class="bi bi-funnel-fill me-1"></i>Filter
                </button>
                @if (hasFilter)
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3">
                        <i class="bi bi-x-lg me-1"></i>Clear
                    </a>
                }
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width:40px">#</th>
                            <th>Period</th>
                            <th>Description</th>
                            <th class="text-center">Employees</th>
                            <th class="text-end">Total Gross</th>
                            <th class="text-end">Total Deductions</th>
                            <th class="text-end">Total Net</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Created</th>
                            <th class="text-center pe-4" style="width:120px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int row = (ViewBag.Page - 1) * ViewBag.PageSize + 1; }
                        @foreach (var b in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@row</td>
                                <td class="fw-semibold">
                                    @(new DateTime(b.Year, b.Month, 1).ToString("MMMM yyyy"))
                                </td>
                                <td class="text-muted small">@(b.Description ?? "—")</td>
                                <td class="text-center">
                                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                                        @b.TotalEmployees
                                    </span>
                                </td>
                                <td class="text-end small">@b.TotalGrossSalary.ToString("N2")</td>
                                <td class="text-end small text-danger">@b.TotalDeductions.ToString("N2")</td>
                                <td class="text-end fw-semibold">@b.TotalNetSalary.ToString("N2")</td>
                                <td class="text-center">
                                    @switch (b.Status)
                                    {
                                        case PayrollBatchStatus.Completed:
                                            <span class="badge rounded-pill bg-success-subtle text-success px-3 py-2">
                                                <i class="bi bi-check-circle-fill me-1"></i>Completed
                                            </span>
                                            break;
                                        case PayrollBatchStatus.Processing:
                                            <span class="badge rounded-pill bg-info-subtle text-info px-3 py-2">
                                                <i class="bi bi-arrow-repeat me-1"></i>Processing
                                            </span>
                                            break;
                                        case PayrollBatchStatus.Submitted:
                                            <span class="badge rounded-pill bg-warning-subtle text-warning px-3 py-2">
                                                <i class="bi bi-hourglass-split me-1"></i>Submitted
                                            </span>
                                            break;
                                        case PayrollBatchStatus.Rejected:
                                            <span class="badge rounded-pill bg-danger-subtle text-danger px-3 py-2">
                                                <i class="bi bi-x-octagon-fill me-1"></i>Rejected
                                            </span>
                                            break;
                                        case PayrollBatchStatus.Cancelled:
                                            <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2">
                                                <i class="bi bi-x-circle-fill me-1"></i>Cancelled
                                            </span>
                                            break;
                                        default:
                                            <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2">
                                                <i class="bi bi-pencil-fill me-1"></i>Draft
                                            </span>
                                            break;
                                    }
                                </td>
                                <td class="text-center small text-muted">@b.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="text-center pe-4">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        @if (b.Status == PayrollBatchStatus.Draft || b.Status == PayrollBatchStatus.Rejected)
                                        {
                                            <form asp-action="Submit" asp-route-id="@b.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-warning" title="Submit for Approval"
                                                        onclick="return confirm('Submit this batch for approval?')">
                                                    <i class="bi bi-send-fill"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                            row++;
                        }
                    </tbody>
                </table>
            </div>
            @await Html.PartialAsync("_Pagination")
        }
        else
        {
            <div class="text-center py-5">
                <div class="empty-state-icon mx-auto mb-3">
                    <i class="bi bi-layers"></i>
                </div>
                @if (hasFilter)
                {
                    <h6 class="fw-semibold text-dark mb-1">No matching batches</h6>
                    <p class="text-muted small mb-4">Try adjusting your filters.</p>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg me-1"></i>Clear Filters
                    </a>
                }
                else
                {
                    <h6 class="fw-semibold text-dark mb-1">No payroll batches yet</h6>
                    <p class="text-muted small mb-4">Create your first batch to begin processing payroll by month.</p>
                    <a asp-action="Create" class="btn btn-primary px-4">
                        <i class="bi bi-plus-lg me-1"></i>New Batch
                    </a>
                }
            </div>
        }
    </div>
</div>
