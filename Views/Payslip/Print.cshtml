@model PayslipViewModel
@{
    Layout = null;
    var statusText  = Model.Status.ToString();
    var statusColor = Model.Status switch {
        PayrollStatus.Paid     => "#198754",
        PayrollStatus.Approved => "#0dcaf0",
        _                      => "#6c757d"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payslip — @Model.EmployeeName — @Model.PayPeriodStart.ToString("MMM yyyy")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: #f4f6fb; font-family: 'Segoe UI', sans-serif; }

        .slip-wrapper {
            max-width: 720px;
            margin: 32px auto;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,.10);
            overflow: hidden;
        }

        .slip-header {
            background: linear-gradient(135deg, #1e2a45, #4361ee);
            color: #fff;
            padding: 28px 36px 20px;
        }
        .slip-header .company   { font-size: 1.25rem; font-weight: 700; letter-spacing:.5px; }
        .slip-header .slip-label{ font-size: .75rem; text-transform: uppercase; letter-spacing: 2px;
                                   opacity:.7; margin-bottom:2px; }
        .slip-header .period    { font-size: 1.5rem; font-weight: 700; }

        .slip-body { padding: 28px 36px; }

        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 24px; margin-bottom: 24px; }
        .info-row  { display: flex; gap: 8px; font-size: .875rem; }
        .info-label{ color: #6c757d; min-width: 90px; }
        .info-value{ font-weight: 600; color: #1e2a45; }

        .section-title {
            font-size: .7rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 1.5px; color: #6c757d; margin-bottom: 8px;
            padding-bottom: 6px; border-bottom: 1px solid #e9ecef;
        }

        .amount-row { display: flex; justify-content: space-between;
                      padding: 6px 0; font-size: .9rem; border-bottom: 1px solid #f1f3f5; }
        .amount-row:last-child { border-bottom: none; }
        .amount-row .label { color: #495057; }
        .amount-row .amount { font-weight: 600; color: #1e2a45; }
        .amount-row.subtotal { background: #f8f9fa; padding: 8px 12px; border-radius: 6px;
                               margin: 6px 0; font-weight: 700; }
        .amount-row.subtotal .label  { color: #1e2a45; }

        .net-box {
            background: linear-gradient(135deg, #4361ee, #3a0ca3);
            color: #fff; border-radius: 10px; padding: 18px 24px;
            display: flex; justify-content: space-between; align-items: center;
            margin-top: 16px;
        }
        .net-box .net-label { font-size: .8rem; text-transform: uppercase;
                              letter-spacing: 1.5px; opacity: .85; }
        .net-box .net-amount{ font-size: 2rem; font-weight: 800; }

        .status-badge {
            display: inline-block; padding: 3px 14px; border-radius: 50px;
            font-size: .75rem; font-weight: 700; color: #fff;
            background: @statusColor;
        }

        .slip-footer { background: #f8f9fa; padding: 14px 36px;
                       font-size: .75rem; color: #6c757d;
                       display: flex; justify-content: space-between; align-items: center; }

        .no-print { margin: 16px auto; max-width: 720px;
                    display: flex; gap: 10px; justify-content: flex-end; }

        @@media print {
            body { background: #fff !important; }
            .no-print { display: none !important; }
            .slip-wrapper { box-shadow: none; margin: 0; border-radius: 0; }
        }
    </style>
</head>
<body>

    <div class="no-print">
        <button onclick="window.print()" class="btn btn-primary">
            <i class="bi bi-printer-fill me-1"></i>Print / Save as PDF
        </button>
        <button onclick="window.close()" class="btn btn-outline-secondary">
            <i class="bi bi-x-lg me-1"></i>Close
        </button>
    </div>

    <div class="slip-wrapper">

        @* Header *@
        <div class="slip-header">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="company"><i class="bi bi-cash-coin me-2"></i>Payroll System</div>
                    <div class="mt-3">
                        <div class="slip-label">Pay Period</div>
                        <div class="period">@Model.PayPeriodStart.ToString("MMMM yyyy")</div>
                        <div style="font-size:.82rem;opacity:.75;margin-top:2px">
                            @Model.PayPeriodStart.ToString("dd MMM yyyy") – @Model.PayPeriodEnd.ToString("dd MMM yyyy")
                        </div>
                    </div>
                </div>
                <div class="text-end">
                    <div class="slip-label">Payslip</div>
                    <div style="font-size:1.1rem;font-weight:700">#@Model.PayrollId.ToString("D6")</div>
                    <div class="mt-2"><span class="status-badge">@statusText</span></div>
                    @if (Model.BatchDescription != null)
                    {
                        <div style="font-size:.75rem;opacity:.7;margin-top:6px">@Model.BatchDescription</div>
                    }
                </div>
            </div>
        </div>

        <div class="slip-body">

            @* Employee Info *@
            <div class="section-title">Employee Details</div>
            <div class="info-grid mb-4">
                <div class="info-row">
                    <span class="info-label">Name</span>
                    <span class="info-value">@Model.EmployeeName</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Payment Scheme</span>
                    <span class="info-value">@Model.PaymentSchemeName</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value">@Model.EmployeeEmail</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Join Date</span>
                    <span class="info-value">@Model.JoinDate.ToString("dd MMM yyyy")</span>
                </div>
                @if (Model.EmployeePhone != null)
                {
                    <div class="info-row">
                        <span class="info-label">Phone</span>
                        <span class="info-value">@Model.EmployeePhone</span>
                    </div>
                }
            </div>

            @* Earnings *@
            <div class="section-title">Earnings</div>
            <div class="mb-3">
                <div class="amount-row">
                    <span class="label">Basic Salary</span>
                    <span class="amount">@Model.BasicSalary.ToString("N2")</span>
                </div>
                <div class="amount-row">
                    <span class="label">
                        Overtime
                        @if (Model.OvertimeHours > 0)
                        {
                            <span class="text-muted" style="font-size:.8rem">
                                (@Model.OvertimeHours.ToString("N1") hrs × $@Model.OvertimeRatePerHour.ToString("N2")/hr)
                            </span>
                        }
                    </span>
                    <span class="amount">@Model.OvertimePay.ToString("N2")</span>
                </div>
                <div class="amount-row">
                    <span class="label">Allowances</span>
                    <span class="amount">@Model.Allowances.ToString("N2")</span>
                </div>
                <div class="amount-row subtotal">
                    <span class="label">Gross Salary</span>
                    <span class="amount">@Model.GrossSalary.ToString("N2")</span>
                </div>
            </div>

            @* Deductions *@
            <div class="section-title">Deductions</div>
            <div class="mb-3">
                <div class="amount-row">
                    <span class="label">Total Deductions</span>
                    <span class="amount text-danger">(@Model.Deductions.ToString("N2"))</span>
                </div>
            </div>

            @* Net Pay *@
            <div class="net-box">
                <div>
                    <div class="net-label">Net Salary</div>
                    <div style="font-size:.78rem;opacity:.75;margin-top:2px">
                        For @Model.PayPeriodStart.ToString("MMMM yyyy")
                    </div>
                </div>
                <div class="net-amount">$@Model.NetSalary.ToString("N2")</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Remarks))
            {
                <div class="mt-3 p-3 bg-light rounded" style="font-size:.85rem">
                    <span class="text-muted fw-semibold">Remarks: </span>@Model.Remarks
                </div>
            }

        </div>

        <div class="slip-footer">
            <span><i class="bi bi-shield-check me-1 text-success"></i>This is a system-generated payslip.</span>
            <span>Generated: @Model.GeneratedAt.ToString("dd MMM yyyy, hh:mm tt")</span>
        </div>

    </div>

    <script src="/js/payslip-print.js"></script>
</body>
</html>
