@model IEnumerable<PaymentScheme>
@{
    ViewData["Title"] = "Payment Schemes";
    bool hasFilter = !string.IsNullOrWhiteSpace(ViewBag.Search as string) || !string.IsNullOrWhiteSpace(ViewBag.Status as string);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-cash-stack me-2 text-primary"></i>Payment Schemes</span>
        <a asp-action="Create" class="btn btn-primary btn-sm px-3">
            <i class="bi bi-plus-lg me-1"></i>Add New
        </a>
    </div>

    @* Filter bar *@
    <div class="card-body border-bottom pb-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-12 col-sm-6 col-md-5">
                <label class="form-label small fw-semibold mb-1">Search</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Scheme name…" />
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-3">
                <label class="form-label small fw-semibold mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    <option value="active"   selected="@(ViewBag.Status == "active"   ? "selected" : null)">Active</option>
                    <option value="inactive" selected="@(ViewBag.Status == "inactive" ? "selected" : null)">Inactive</option>
                </select>
            </div>
            <div class="col-6 col-sm-auto d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary px-3">
                    <i class="bi bi-funnel-fill me-1"></i>Filter
                </button>
                @if (hasFilter)
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3">
                        <i class="bi bi-x-lg me-1"></i>Clear
                    </a>
                }
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width:40px">#</th>
                            <th>Name</th>
                            <th class="text-end">Basic Salary</th>
                            <th class="text-end">Overtime Rate / Hr</th>
                            <th class="text-end">Allowance</th>
                            <th class="text-center">Status</th>
                            <th class="text-center pe-4" style="width:120px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int row = (ViewBag.Page - 1) * ViewBag.PageSize + 1; }
                        @foreach (var scheme in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@row</td>
                                <td class="fw-semibold">@scheme.Name</td>
                                <td class="text-end">@scheme.BasicSalary.ToString("N2")</td>
                                <td class="text-end">@scheme.OvertimeRatePerHour.ToString("N2")</td>
                                <td class="text-end">@scheme.AllowanceAmount.ToString("N2")</td>
                                <td class="text-center">
                                    @if (scheme.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success px-3 py-2">
                                            <i class="bi bi-check-circle-fill me-1"></i>Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2">
                                            <i class="bi bi-x-circle-fill me-1"></i>Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <a asp-action="Edit" asp-route-id="@scheme.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                </td>
                            </tr>
                            row++;
                        }
                    </tbody>
                </table>
            </div>
            @await Html.PartialAsync("_Pagination")
        }
        else
        {
            <div class="text-center py-5">
                <div class="empty-state-icon mx-auto mb-3">
                    <i class="bi bi-cash-stack"></i>
                </div>
                @if (hasFilter)
                {
                    <h6 class="fw-semibold text-dark mb-1">No matching schemes</h6>
                    <p class="text-muted small mb-4">Try adjusting your filters.</p>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg me-1"></i>Clear Filters
                    </a>
                }
                else
                {
                    <h6 class="fw-semibold text-dark mb-1">No payment schemes yet</h6>
                    <p class="text-muted small mb-4">Add your first payment scheme to get started.</p>
                    <a asp-action="Create" class="btn btn-primary px-4">
                        <i class="bi bi-plus-lg me-1"></i>Add Payment Scheme
                    </a>
                }
            </div>
        }
    </div>
</div>
