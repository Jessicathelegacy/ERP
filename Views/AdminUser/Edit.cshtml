@model AdminUserEditViewModel
@{
    ViewData["Title"] = "Edit Admin User";
    var allRoles = ViewBag.AllRoles as List<Role> ?? [];
    var selectedIds = Model.SelectedRoleIds;
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="bi bi-shield-fill me-2 text-primary"></i>
                    <span class="fw-semibold">Edit Admin User</span>
                </div>
                <a asp-action="ChangePassword" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning px-3">
                    <i class="bi bi-key-fill me-1"></i>Change Password
                </a>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold">
                            Username <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                            <input asp-for="Username" class="form-control" autocomplete="username" />
                        </div>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" role="switch" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                        </div>
                    </div>

                    @* Roles *@
                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-tags-fill me-1 text-primary"></i>Roles
                        </label>
                        @if (allRoles.Any())
                        {
                            <div class="border rounded-3 p-3 bg-light">
                                @foreach (var role in allRoles)
                                {
                                    <div class="form-check mb-1">
                                        <input class="form-check-input" type="checkbox"
                                               name="SelectedRoleIds" value="@role.Id"
                                               id="role_@role.Id"
                                               @(selectedIds.Contains(role.Id) ? "checked" : "") />
                                        <label class="form-check-label" for="role_@role.Id">
                                            <span class="fw-semibold">@role.Name</span>
                                            @if (!string.IsNullOrWhiteSpace(role.Description))
                                            {
                                                <span class="text-muted small ms-1">— @role.Description</span>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small border rounded-3 p-3">
                                No active roles available.
                                <a asp-controller="Role" asp-action="Create">Create a role first.</a>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
